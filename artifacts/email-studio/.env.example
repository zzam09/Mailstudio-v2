# Required for Turso / LibSQL persistence
VITE_TURSO_DATABASE_URL=libsql://your-db.turso.io
VITE_TURSO_AUTH_TOKEN=your-auth-token

# Leave VITE_TURSO_DATABASE_URL unset to silently fall back to localStorage.
# You can also swap to another LibSQL-compatible URL here without changing app code.
# Example local SQLite-compatible URL:
# VITE_TURSO_DATABASE_URL=file:///absolute/path/to/local.db
